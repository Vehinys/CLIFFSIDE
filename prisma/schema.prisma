generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// AUTH (Auth.js / NextAuth v5)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  roleId        String?
  role          Role?     @relation(fields: [roleId], references: [id])
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// RBAC — RÔLES & PERMISSIONS
// ─────────────────────────────────────────────

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  color       String       @default("#6b7280")
  description String?
  isSystem    Boolean      @default(false) // rôle ADMIN non supprimable
  users       User[]
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// resource: "members" | "inventory" | "treasury" | "roles" | "dashboard"
// action:   "read"   | "create"    | "update"   | "delete"
model Permission {
  id       String @id @default(cuid())
  roleId   String
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  resource String
  action   String

  @@unique([roleId, resource, action])
}


// ─────────────────────────────────────────────
// INVENTAIRE
// ─────────────────────────────────────────────

model InventoryCategory {
  id    String          @id @default(cuid())
  name  String          @unique // ex: "Armes", "Véhicules", "Ressources"
  icon  String?
  items InventoryItem[]
}

model InventoryItem {
  id          String            @id @default(cuid())
  name        String
  description String?
  quantity    Int               @default(0)
  unit        String?           // ex: "unité", "kg", "caisse"
  minStock    Int?              // seuil alerte stock bas
  categoryId  String
  category    InventoryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  activatedAt DateTime?         // Date d'activation optionnelle
  expiresAt   DateTime?         // Date d'expiration optionnelle
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

// ─────────────────────────────────────────────
// TRÉSORERIE
// ─────────────────────────────────────────────

enum TransactionType {
  INCOME
  EXPENSE
}

model TreasuryTransaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Int             // montant en $ (monnaie du jeu)
  description String
  category    String?         // ex: "Vente", "Achat", "Salaire"
  createdById String          // ID du User auteur
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}
