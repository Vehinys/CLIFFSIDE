generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// AUTH (Auth.js / NextAuth v5)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  isSuperAdmin  Boolean   @default(false)
  roleId        String?
  role          Role?     @relation(fields: [roleId], references: [id])
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// RBAC — RÔLES & PERMISSIONS
// ─────────────────────────────────────────────

model Role {
  id                  String              @id @default(cuid())
  name                String              @unique
  color               String              @default("#6b7280")
  description         String?
  isSystem            Boolean             @default(false) // rôle ADMIN non supprimable
  users               User[]
  permissions         Permission[]
  inventoryCategories InventoryCategory[] @relation("InventoryCategoryRoles")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

// resource: "members" | "inventory" | "treasury" | "roles" | "dashboard"
//           "objectives" | "secretariat"
// action:   "read"   | "create"    | "update"   | "delete"
model Permission {
  id       String @id @default(cuid())
  roleId   String
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  resource String
  action   String

  @@unique([roleId, resource, action])
}


// ─────────────────────────────────────────────
// INVENTAIRE
// ─────────────────────────────────────────────

model InventoryCategory {
  id    String          @id @default(cuid())
  name  String          @unique // ex: "Armes", "Véhicules", "Ressources"
  icon  String?
  items InventoryItem[]
  roles Role[]          @relation("InventoryCategoryRoles")
}

model InventoryItem {
  id          String            @id @default(cuid())
  name        String
  description String?
  quantity    Int               @default(0)
  unit        String?           // ex: "unité", "kg", "caisse"
  minStock    Int?              // seuil alerte stock bas
  categoryId  String
  category    InventoryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  activatedAt DateTime?         // Date d'activation optionnelle
  expiresAt   DateTime?         // Date d'expiration optionnelle
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

// ─────────────────────────────────────────────
// JOURNAL D'AUDIT (toutes sections)
// ─────────────────────────────────────────────

// section : inventory | treasury | members | roles | secretariat
// action  : CREATE | UPDATE | DELETE | QTY_ADD | QTY_SUB
//           CATEGORY_CREATE | CATEGORY_UPDATE | CATEGORY_DELETE
//           ROLE_UPDATE
//           ANNOUNCE_CREATE | ANNOUNCE_DELETE
//           REPORT_CREATE | REPORT_DELETE
//           NOTE_CREATE | NOTE_UPDATE | NOTE_DELETE
//           TASK_CREATE | TASK_UPDATE | TASK_DELETE
model AuditLog {
  id         String   @id @default(cuid())
  section    String
  action     String
  targetName String                   // dénormalisé (conservé après suppression)
  userId     String
  userName   String?
  details    String?
  createdAt  DateTime @default(now())

  @@index([section, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────
// TRÉSORERIE
// ─────────────────────────────────────────────

enum TransactionType {
  INCOME
  EXPENSE
}

// ─────────────────────────────────────────────
// PRÉSENCE QUOTIDIENNE & OBJECTIFS
// ─────────────────────────────────────────────

model DailySession {
  id          String            @id @default(cuid())
  date        DateTime          @unique // minuit heure serveur
  attendances DailyAttendance[]
  objectives  DailyObjective[]
  createdAt   DateTime          @default(now())
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

model DailyAttendance {
  id        String           @id @default(cuid())
  sessionId String
  session   DailySession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  userName  String?
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([sessionId, userId])
  @@index([sessionId])
}

model DailyObjective {
  id            String       @id @default(cuid())
  sessionId     String
  session       DailySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  content       String
  done          Boolean      @default(false)
  createdById   String
  createdByName String?
  createdAt     DateTime     @default(now())

  @@index([sessionId])
}

// ─────────────────────────────────────────────
// SECRÉTARIAT
// ─────────────────────────────────────────────

model Announcement {
  id            String   @id @default(cuid())
  title         String
  content       String
  imageUrl      String?
  createdById   String
  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MeetingReport {
  id            String   @id @default(cuid())
  title         String
  content       String
  imageUrl      String?
  meetingDate   DateTime
  createdById   String
  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SharedNote {
  id            String   @id @default(cuid())
  title         String
  content       String
  imageUrl      String?
  createdById   String
  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model SecretariatTask {
  id             String     @id @default(cuid())
  title          String
  description    String?
  assignedToId   String?
  assignedToName String?
  status         TaskStatus @default(TODO)
  createdById    String
  createdByName  String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

// ─────────────────────────────────────────────
// TRÉSORERIE
// ─────────────────────────────────────────────

model TreasuryTransaction {
  id            String          @id @default(cuid())
  type          TransactionType
  amount        Int             // montant en $ (monnaie du jeu)
  description   String
  category      String?         // ex: "Vente", "Achat", "Salaire"
  createdById   String          // ID du User auteur
  createdByName String?         // dénormalisé
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}
