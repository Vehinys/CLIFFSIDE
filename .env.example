# ─────────────────────────────────────────────
# CLIFFSIDE — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS committer .env.local
# ─────────────────────────────────────────────

# Base de données — Neon PostgreSQL
# Pooled connection (pour les requêtes app)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require&pgbouncer=true"

# Direct connection (pour les migrations Prisma)
DIRECT_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Auth.js v5
# Générer avec : openssl rand -hex 32
AUTH_SECRET="your-secret-here"

# URL du site (sans slash final)
# Développement : http://localhost:3000
# Production    : https://cliffside.vercel.app
AUTH_URL="http://localhost:3000"
